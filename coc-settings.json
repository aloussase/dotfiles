{
    "languageserver": {
        "haskell": {
            "command": "haskell-language-server-wrapper",
            "args": [
                "--lsp"
            ],
            "rootPatterns": [
                "*.cabal",
                "stack.yaml",
                "cabal.project",
                "package.yaml",
                "hie.yaml"
            ],
            "filetypes": [
                "haskell",
                "lhaskell"
            ],
            "settings": {
                "haskell": {
                    "checkProject": true,
                    "formattingProvider": "stylish-haskell",
                    "plugin": {
                        "hlint": {
                            "globalOn": true
                        }
                    }
                }
            }
        }
    }
}
